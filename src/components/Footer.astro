---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-left">
			<a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
			<span>&</span>
			<a href="https://github.com/cworld1/astro-theme-pure" target="_blank" rel="noopener">Pure theme</a>
			<span>powered</span>
		</div>
		<div class="footer-center">
			&copy; {today.getFullYear()} DINGYURS
		</div>
		<div class="footer-right">
			<a href="https://www.travellings.cn/train.html" target="_blank" rel="noopener" class="travelling-link">
				<span>Travelling</span>
			</a>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: var(--space-6) var(--space-4);
		border-top: 1px solid var(--color-border);
		margin-top: var(--space-12);
	}

	.footer-content {
		max-width: var(--max-width-wide);
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}

	.footer-left {
		display: flex;
		align-items: center;
		gap: var(--space-2);
	}

	.footer-left a {
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.footer-left a:hover {
		color: var(--color-primary);
	}

	.footer-center {
		color: var(--color-text-muted);
	}

	.footer-right {
		display: flex;
		align-items: center;
	}

	.travelling-link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		color: var(--color-text-secondary);
		text-decoration: none;
		padding: var(--space-1) var(--space-3);
		border-radius: var(--radius);
		transition: all var(--transition-fast);
	}

	.travelling-link:hover {
		color: var(--color-primary);
		background: color-mix(in srgb, var(--color-primary) 8%, transparent);
	}

	@media (max-width: 768px) {
		.footer-content {
			flex-direction: column;
			gap: var(--space-3);
			text-align: center;
		}
	}
</style>
