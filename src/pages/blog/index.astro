---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date): string {
	return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}

function padNumber(n: number): string {
	return String(n).padStart(2, '0');
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-page">
				<div class="page-header animate" style="animation-delay: 50ms">
					<h1>文章</h1>
					<p>{SITE_DESCRIPTION}</p>
				</div>
				<div class="article-list animate" style="animation-delay: 100ms">
					{posts.map((post, index) => (
						<a href={`/blog/${post.id}/`} class="article-item">
							{post.data.heroImage && (
								<div class="article-cover">
									<img src={post.data.heroImage.src} alt={post.data.title} loading="lazy" />
								</div>
							)}
							<div class="article-number">{padNumber(index + 1)}</div>
							<div class="article-info">
								<div class="article-meta">
									<time>{formatDate(post.data.pubDate)}</time>
									<span class="article-title">{post.data.title}</span>
								</div>
								{post.data.description && (
									<p class="article-desc">{post.data.description}</p>
								)}
							</div>
						</a>
					))}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-page {
		max-width: var(--max-width-wide);
		margin: 0 auto;
		padding: 0 var(--space-6) var(--space-12);
	}

	.page-header {
		padding: var(--space-10) 0 var(--space-8);
	}

	.page-header h1 {
		font-size: var(--text-3xl);
		font-weight: 700;
		margin-bottom: var(--space-3);
	}

	.page-header p {
		color: var(--color-text-secondary);
		font-size: var(--text-base);
		margin: 0;
	}

	/* Article List */
	.article-list {
		display: flex;
		flex-direction: column;
	}

	.article-item {
		display: flex;
		align-items: flex-start;
		gap: var(--space-4);
		padding: var(--space-5) 0;
		border-bottom: 1px dashed var(--color-border);
		text-decoration: none;
		color: inherit;
		transition: all var(--transition-fast);
	}

	.article-item:hover {
		background: color-mix(in srgb, var(--color-primary) 4%, transparent);
	}

	.article-item:last-child {
		border-bottom: none;
	}

	.article-cover {
		flex-shrink: 0;
		width: 160px;
		height: 100px;
		border-radius: var(--radius);
		overflow: hidden;
	}

	.article-cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.article-number {
		flex-shrink: 0;
		font-size: var(--text-2xl);
		font-weight: 700;
		color: var(--color-border);
		min-width: 2rem;
		text-align: right;
		line-height: 1;
		padding-top: 2px;
	}

	.article-info {
		flex: 1;
		min-width: 0;
	}

	.article-meta {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		margin-bottom: var(--space-2);
	}

	.article-meta time {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		font-family: var(--font-mono);
	}

	.article-title {
		font-size: var(--text-lg);
		font-weight: 600;
		color: var(--color-text);
		line-height: 1.4;
	}

	.article-item:hover .article-title {
		color: var(--color-primary);
	}

	.article-desc {
		font-size: var(--text-sm);
		color: var(--color-text-secondary);
		margin: 0;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media (max-width: 768px) {
		.blog-page {
			padding: 0 var(--space-4) var(--space-8);
		}

		.page-header {
			padding: var(--space-6) 0 var(--space-5);
		}

		.article-cover {
			display: none;
		}
	}
</style>
