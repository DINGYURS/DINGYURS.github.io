---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, GITHUB_URL } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`关于 | ${SITE_TITLE}`} description="计算机学习者、技术记录者、摄影爱好者" />
	</head>
	<body>
		<Header />
		<main>
			<div class="about-page">
				<div class="page-header animate" style="animation-delay: 50ms">
					<h1>关于</h1>
				</div>
				<article class="about-content animate" style="animation-delay: 100ms">
					<h2>About Me</h2>
					<ul>
						<li>Developer / Learner / 摄影爱好者</li>
						<li>记录计算机学习中的问题、思考与实践</li>
					</ul>

					<h2>Skills</h2>
					<div class="skills-section">
						<div class="skill-row">
							<span class="skill-badge">JavaScript</span>
							<span class="skill-badge">TypeScript</span>
							<span class="skill-badge">Vue</span>
							<span class="skill-badge">Astro</span>
						</div>
						<div class="skill-row">
							<span class="skill-badge">Python</span>
							<span class="skill-badge">HTML/CSS</span>
							<span class="skill-badge">Git</span>
							<span class="skill-badge">Linux</span>
						</div>
					</div>

					<h2>Tech Stack</h2>
					<p>
						博客基于 <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> 构建，
						使用 <a href="https://pages.github.com" target="_blank" rel="noopener">GitHub Pages</a> 部署。
						使用 Markdown 撰写文章，追求简洁、易读、内容优先的风格。
					</p>

					<h2>About Blog</h2>
					<p>
						这是一个记录计算机学习过程的个人技术博客。我会在这里整理遇到的技术问题、
						环境配置经验、Bug 排查过程，以及一些学习心得和项目复盘。
					</p>

					<h3>主要内容</h3>
					<ul>
						<li>技术 Bug 排查与解决方案</li>
						<li>开发环境配置记录</li>
						<li>前端开发学习笔记</li>
						<li>项目开发经验总结</li>
						<li>摄影作品与拍摄记录</li>
					</ul>

					<h3>建站工具链</h3>
					<ul>
						<li>Framework: <a href="https://astro.build" target="_blank" rel="noopener">Astro</a></li>
						<li>Hosting: <a href="https://pages.github.com" target="_blank" rel="noopener">GitHub Pages</a></li>
						<li>Icons: <a href="https://iconify.design/" target="_blank" rel="noopener">Iconify</a></li>
					</ul>

					<h2>Contact</h2>
					<p>
						可以通过 <a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a> 联系我。
					</p>
				</article>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-page {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--space-6) var(--space-12);
	}

	.page-header {
		padding: var(--space-10) 0 var(--space-6);
	}

	.page-header h1 {
		font-size: var(--text-3xl);
		font-weight: 700;
	}

	.about-content h2 {
		font-size: var(--text-2xl);
		margin-top: var(--space-10);
		margin-bottom: var(--space-4);
		padding-bottom: var(--space-2);
		border-bottom: 1px solid var(--color-border);
	}

	.about-content h3 {
		font-size: var(--text-xl);
		margin-top: var(--space-6);
		margin-bottom: var(--space-3);
	}

	.about-content p {
		color: var(--color-text-secondary);
		line-height: 1.8;
	}

	.about-content ul {
		padding-left: var(--space-5);
		margin-bottom: var(--space-4);
	}

	.about-content li {
		margin-bottom: var(--space-2);
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	/* Skills */
	.skills-section {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		margin-bottom: var(--space-4);
	}

	.skill-row {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.skill-badge {
		display: inline-block;
		padding: var(--space-1) var(--space-3);
		background: var(--color-bg-secondary);
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border);
		border-radius: 9999px;
		font-size: var(--text-sm);
		transition: all var(--transition-fast);
	}

	.skill-badge:hover {
		border-color: var(--color-primary);
		color: var(--color-primary);
		background: color-mix(in srgb, var(--color-primary) 8%, transparent);
	}

	@media (max-width: 768px) {
		.about-page {
			padding: 0 var(--space-4) var(--space-8);
		}

		.page-header {
			padding: var(--space-6) 0 var(--space-4);
		}
	}
</style>
